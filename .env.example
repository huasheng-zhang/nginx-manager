# ========================================
# Nginx Manager 生产环境配置示例
# ========================================

# ========== Django 核心设置 ==========

# 密钥（必须修改！使用命令生成：python -c "import secrets; print(secrets.token_urlsafe(50))"）
SECRET_KEY=your-secret-key-here-change-in-production

# 允许访问的主机（逗号分隔）
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com

# 管理员 URL（建议修改为随机字符串以增强安全性）
DJANGO_ADMIN_URL=admin

# ========== 数据库设置 ==========

# PostgreSQL 密码（必须修改！）
DB_PASSWORD=strong-db-password-123

# ========== Redis 设置 ==========

# Redis 密码（必须修改！）
REDIS_PASSWORD=strong-redis-password-456

# ========== Django 超级用户 ==========

# 首次启动时自动创建超级用户
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@your-domain.com
DJANGO_SUPERUSER_PASSWORD=strong-admin-password-789

# ========== 邮件设置（用于告警） ==========

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Nginx Manager <noreply@your-domain.com>

# 管理员邮箱
ADMIN_EMAIL=admin@your-domain.com

# ========== SSH 设置 ==========

# SSH 连接超时（秒）
SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=30

# ========== 监控设置 ==========

# 监控数据保留时间（天）
MONITORING_DATA_RETENTION_DAYS=30

# 日志数据保留时间（天）
LOG_DATA_RETENTION_DAYS=7

# ========== 第三方告警集成（可选） ==========

# 钉钉 Webhook
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_token_here
DINGTALK_SECRET=your_dingtalk_secret

# 企业微信 Webhook
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here

# ========== 性能调优 ==========

# Gunicorn Worker 数量（CPU 核心数 * 2 + 1）
WEB_WORKERS=4

# 每个 Worker 的线程数
WEB_THREADS=2

# ========== SSL/TLS 设置 ==========

# 强制 HTTPS 重定向
SECURE_SSL_REDIRECT=True

# ========== 调试模式（生产环境必须为 False） ==========

# 仅在排查问题时临时启用
DEBUG=False
